<!DOCTYPE html>
<html lang="{{ metadata.language }}">
  <head lang="{{ metadata.language }}">
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{% if page.url == '/' %}{{ metadata.title }} | Home{% elif title %}{{ title }} - {{ metadata.title }}{% else %}{{ metadata.title }}{% endif %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{ description or metadata.description }}" />
    <meta name="generator" content="Eleventy v{{ eleventyVersion }}" />
    <link rel="icon" type="image/png" href="{{ metadata.favicon }}" />
    <link rel="apple-touch-icon" href="{{ metadata.favicon }}" />
    <link rel="alternate" type="application/atom+xml" title="{{ metadata.title }} Atom" href="/feed/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="{{ metadata.title }} RSS" href="/feed/feed.rss" />
    <link rel="alternate" type="application/feed+json" title="{{ metadata.title }} JSON Feed" href="/feed/feed.json" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@1,500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Sans&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto+Mono" />
    <link rel="stylesheet" href="/css/main.css" />
    <link id="darkModeStyle" rel="stylesheet" href="/css/dark.css" disabled />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ metadata.title | dump | safe }},
        "url": {{ metadata.url | dump | safe }},
        "description": {{ metadata.description | dump | safe }},
        "inLanguage": {{ metadata.language | dump | safe }}
      }
    </script>
  </head>
  <body>
    <div class="content">
      <header>
        <div class="main">
          <a class="u-url" href="/">{{ metadata.title }}</a>
        </div>
        <nav>
          {% for item in metadata.navigation %}
          <a href="{{ item.url }}">{{ item.label }}</a>
          {% endfor %}
          <button id="dark-mode-toggle" class="nav-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-brightness-high" viewBox="0 0 16 16">
              <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
            </svg>
          </button>
          <script src="/js/themetoggle.js"></script>
        </nav>
      </header>

      <div class="h-card" style="position:absolute;left:-9999px;">
        <a class="p-name u-url" href="{{ metadata.url }}">{{ metadata.title }}</a>
        <img class="u-photo" src="{{ metadata.favicon }}" alt="{{ metadata.title }}" />
        <p class="p-note">{{ metadata.description }}</p>
      </div>

      <main data-pagefind-body>
        {{ content | safe }}
      </main>

      <footer>
        <div style="display:flex">
          {% for item in metadata.social %}
          <a class="soc" href="{{ item.url }}" rel="me" title="{{ item.name }}">
            {% if item.icon == 'github' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-github" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
            {% elif item.icon == 'twitter' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-twitter-x" viewBox="0 0 16 16">
              <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z"/>
            </svg>
            {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-git" viewBox="0 0 16 16">
              <path d="M15.698 7.287 8.712.302a1.03 1.03 0 0 0-1.457 0l-1.45 1.45 1.84 1.84a1.223 1.223 0 0 1 1.55 1.56l1.773 1.774a1.224 1.224 0 0 1 1.267 2.025 1.226 1.226 0 0 1-2.002-1.334L8.58 5.963v4.353a1.226 1.226 0 1 1-1.008-.036V5.887a1.226 1.226 0 0 1-.666-1.608L5.093 2.465l-4.79 4.79a1.03 1.03 0 0 0 0 1.457l6.986 6.986a1.03 1.03 0 0 0 1.457 0l6.953-6.953a1.03 1.03 0 0 0 0-1.457"/>
            </svg>
            {% endif %}
          </a>
          {% if not loop.last %}<span class="pipe" aria-hidden="true">|</span>{% endif %}
          {% endfor %}
        </div>
        <div class="footer-info">
          {{ metadata.deploy_date | deployYear }} {{ metadata.copyright }} |
          <a href="https://github.com/athul/archie">Archie Theme</a> |
          Built with <a href="https://11ty.dev">11ty</a> {{ eleventyVersion }} on {{ metadata.deploy_date | deployYear }}
        </div>
      </footer>
    </div>

    <script src="/pagefind/pagefind-ui.js"></script>
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        const node = document.getElementById("search");
        if (node && window.PagefindUI) {
          new window.PagefindUI({ element: "#search", showSubResults: true, resetStyles: false });
        }
      });
    </script>
  </body>
</html>
