---
layout: layouts/base.njk
title: All posts
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: "/blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<main class="list">
  <div class="site-description"><p>All posts</p></div>
  {% for post in posts %}
  <section class="list-item">
    <h1 class="title"><a href="{{ post.url }}">{{ post.data.title }}</a></h1>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
    <br />
    <div class="description">{{ post.data.description or post.templateContent | striptags | truncate(180) }}</div>
    <a class="readmore" href="{{ post.url }}">Read more ⟶</a>
  </section>
  {% endfor %}
  {% include "paginator.njk" %}
</main>
